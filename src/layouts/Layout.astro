---
import Footer from "../components/Footer.astro";
import Header from "../components/header.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;
---
<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="author" content="anabelHumor">
		<meta name="description" content="Portfolio de anabelhumor desarrolladora front end. "/>
		<meta name="viewport" content="width=device-width" />
		<meta name="description" content="Portafolio de Anabel Huanca Moreano - anabelhumor">
		<link rel="icon" type="image/svg+xml" href="perfil.jpg" />
		<meta name="robots" content="index, follow">
		<link rel="stylesheet" href="/src/css/global.css">

		<!-- OPEN GRAPH -->
		<meta property="og:title" content="Portafolio de Anabel Huanca Moreano @anabelhumor">
		<meta property="og:image" content="/portafolio.JPG">
		<meta property="og:image:alt" content="Una captura de mi portafolio">

		<title>{title}</title>
	</head>
	<body>
		<Header/>
		<slot />
		<Footer/>
	</body>
</html>
<style is:global>
	*{
		box-sizing: border-box;
	}

	html {
		font-family: 'Poppins', sans-serif;
		scroll-behavior: smooth;
		background: #04152D;
	}

	:root {
		color-scheme: light dark;
		--primary: #72c7ff;
		--secondary: #6E6D8F;
	}

	body{
		display: flex;
		flex-direction: column;
		height: 100vh;
	}

	@font-face {
	font-family: 'Poppins Regular';
	font-weight: normal;
	font-style: normal;
	src: url('/fonts/poppins-regular.ttf') format('ttf');
	}

	@font-face {
	font-family: 'Poppins Medium';
	font-weight: 500;
	font-style: normal;
	src: url('/fonts/poppins-medium.ttf') format('ttf');
	}

	@font-face {
	font-family: 'Poppins Semibold';
	font-weight: 700;
	font-style: normal;
	src: url('/fonts/poppins-semibold.ttf') format('ttf');
	}

	@font-face {
	font-family: 'Poppins Bold';
	font-weight: 700;
	font-style: normal;
	src: url('/fonts/poppins-bold.ttf') format('ttf');
	}


	.poppins-regular {
	font-family: "Poppins Regular", sans-serif;
	font-weight: 400;
	font-style: normal;
	}
	
	.poppins-medium {
		font-family: "Poppins Medium", sans-serif;
		font-weight: 500;
		font-style: normal;
	}

	.poppins-semibold {
		font-family: "Poppins SemiBold", sans-serif;
		font-weight: 600;
		font-style: normal;
	}

	.poppins-bold {
		font-family: 'Poppins Bold', sans-serif;
		font-weight: 700;
		font-style: normal;
	}


	h1{
		font-family: 'Poppins Bold', 'Segoe UI';
	}

	h3{
		color: var(--primary);
	}

	strong{
		color: var(--primary);
	}

	.time{
		color: var(--secondary);
		font-weight: bold;
	}

	@media (prefers-reduce-motion: reduce) {
		html{
			scroll-behavior: auto;
		}
	}

</style>
